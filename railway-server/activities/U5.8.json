    { "type": "Text",         "x":  3, "y":  0, "text": "sigma1=6, n1=36; sigma2=8, n2=64. SD of (x-bar1 - x-bar2) = sqrt(sigma1^2/n1 + sigma2^2/n2) = ?" },
    { "type": "SipStation",   "id": "s1", "x":  4, "y":  2, "drink": "A" },
